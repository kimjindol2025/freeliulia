{
  "name": "FreeLiulia",
  "scopeName": "source.fl",
  "fileTypes": ["fl"],
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#string"
    },
    {
      "include": "#number"
    },
    {
      "include": "#keyword"
    },
    {
      "include": "#boolean"
    },
    {
      "include": "#identifier"
    },
    {
      "include": "#operator"
    },
    {
      "include": "#builtin"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.fl",
          "match": "#.*$",
          "comment": "한글 주석 (# 이후 끝까지)"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.fl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.fl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.fl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.fl",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.fl",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.fl",
          "match": "\\b(함수|변수|상수|만약|아니면|아니면만약|반복|동안|반환|끝|없음|참|거짓|구조체|배열|모듈|임포트|익스포트)\\b"
        }
      ]
    },
    "boolean": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.fl",
          "match": "\\b참\\b"
        },
        {
          "name": "constant.language.boolean.false.fl",
          "match": "\\b거짓\\b"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "name": "variable.other.fl",
          "match": "[가-힣_][가-힣0-9_]*"
        },
        {
          "name": "variable.other.english.fl",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.fl",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.fl",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.fl",
          "match": "\\b(그리고|또는|아니)\\b"
        },
        {
          "name": "keyword.operator.assignment.fl",
          "match": "="
        },
        {
          "name": "punctuation.separator.fl",
          "match": "[,;]"
        }
      ]
    },
    "builtin": {
      "patterns": [
        {
          "name": "support.function.builtin.fl",
          "match": "\\b(길이|포함|시작|끝|찾기|대문자|소문자|연결|자르기|바꾸기|반복|채우기|나누기_앞|나누기_뒷|절대값|제곱|제곱근|올림|내림|반올림|최대값|최소값|거듭제곱|배열길이|배열합계|배열평균|배열최대|배열최소|배열포함|정수인가|실수인가|논리값인가|문자열인가|파일열기|파일닫기|줄읽기|줄쓰기|파일존재|파일삭제|파일크기|파일전체읽기|인쇄|입력)\\b"
        }
      ]
    }
  }
}
